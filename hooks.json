{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "powershell": "& (Join-Path $HOME '.copilot\\installed-plugins\\oh-my-copilot\\scripts\\session-start.ps1')",
        "bash": "pwsh -NoProfile -File \"$HOME/.copilot/installed-plugins/oh-my-copilot/scripts/session-start.ps1\"",
        "timeoutSec": 15
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "powershell": "& (Join-Path $HOME '.copilot\\installed-plugins\\oh-my-copilot\\scripts\\session-end.ps1')",
        "bash": "pwsh -NoProfile -File \"$HOME/.copilot/installed-plugins/oh-my-copilot/scripts/session-end.ps1\"",
        "timeoutSec": 45
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "powershell": "& (Join-Path $HOME '.copilot\\installed-plugins\\oh-my-copilot\\scripts\\pre-tool-use.ps1')",
        "bash": "pwsh -NoProfile -File \"$HOME/.copilot/installed-plugins/oh-my-copilot/scripts/pre-tool-use.ps1\"",
        "timeoutSec": 5
      }
    ]
  }
}
